      ! ===========================================
      !
      !  2D ISING MODEL - UNIFIED SIMULATOR
      !  Metropolis, Glauber, and Wolff
      !  For L = 16, 32, 64, 128, 256
      !
      ! ===========================================
      PROGRAM SIMULATOR
      IMPLICIT NONE
      INTEGER iL, L
      INTEGER L_values(5)
      DATA L_values /16, 32, 64, 128, 256/

      do iL = 1, 5
        L = L_values(iL)
        print*, '========================================='
        print*, ' Running simulations for L =', L
        print*, '========================================='
        call RUN_METROPOLIS(L)
        call RUN_GLAUBER(L)
        call RUN_WOLFF(L)
      end do

      END PROGRAM


      ! ===========================================
      !      INITIALIZE LATTICE SUBROUTINE
      ! ===========================================
      SUBROUTINE INITIALIZE(matrix, SIZE, E, M, JMAG)
      IMPLICIT NONE
      INTEGER i, j, SIZE, matrix(SIZE,SIZE), JMAG
      REAL*8 sum, E, M

      do i = 1, SIZE
        do j = 1, SIZE
          call random_number(sum)
          matrix(i,j) = 2*nint(sum) - 1
        end do
      end do

      E = 0
      M = 0
      do i = 1, SIZE
        do j = 1, SIZE
          if (i+1.gt.SIZE) then
            sum = matrix(1,j)
          else
            sum = matrix(i+1,j)
          end if
          if (j+1.gt.SIZE) then
            sum = sum + matrix(i,1)
          else
            sum = sum + matrix(i,j+1)
          end if
          M = M + matrix(i,j)
          E = E - JMAG*matrix(i,j)*sum
        end do
      end do

      END SUBROUTINE


      ! ===========================================
      !           RUN METROPOLIS
      ! ===========================================
      SUBROUTINE RUN_METROPOLIS(L)
      IMPLICIT NONE
      INTEGER L, N, DIM, JMAG, STEPS
      PARAMETER(DIM=2, JMAG=1, STEPS=20000)
      INTEGER, ALLOCATABLE :: matrix(:,:)
      REAL*8, ALLOCATABLE :: energies(:), mags(:)
      REAL*8 exponentials(0:DIM), E, M
      REAL*8 avg_e, avg_m, avg_e2
      REAL itemp, dtemp, ftemp
      INTEGER i, j, k
      CHARACTER(256) fname

      N = L*L
      ALLOCATE(matrix(L,L))
      ALLOCATE(energies(STEPS), mags(STEPS))

      itemp = 0.2
      dtemp = 0.2
      ftemp = 5.0

      call INITIALIZE(matrix, L, E, M, JMAG)

      write(fname,'(A,I0,A)') 'metropolis_2d_L', L, '.txt'
      open(10, File=trim(fname))

      do i = int((ftemp-itemp)/dtemp), 0, -1
        print*, "  [Metropolis] T =", itemp+i*dtemp
        do k = 0, DIM
          exponentials(k) =
     &      exp(-2.0*JMAG*2.0*k/(itemp+i*dtemp))
        end do

        energies = 0
        mags = 0
        do j = 1, STEPS
          call METROPOLIS_MC_STEP(matrix, L, E, M,
     &                           N, DIM, exponentials)
          energies(j) = E
          mags(j) = M
        end do

        avg_e = 0
        avg_m = 0
        avg_e2 = 0
        do j = 6001, STEPS
          avg_e = avg_e + energies(j)
          avg_m = avg_m + abs(mags(j))
          avg_e2 = avg_e2 + (energies(j)**2)
        end do
        write(10,*) itemp+i*dtemp, avg_e/14000/N,
     &    avg_m/14000/N,
     &    (avg_e2/14000 - (avg_e/14000)**2)
     &    /(N*dble(itemp+i*dtemp)**2)
      end do

      close(10)
      DEALLOCATE(matrix, energies, mags)

      END SUBROUTINE


      ! ===========================================
      !      METROPOLIS MONTE CARLO STEP
      ! ===========================================
      SUBROUTINE METROPOLIS_MC_STEP(matrix, SIZE,
     &            E, M, N, DIM, exponentials)
      IMPLICIT NONE
      INTEGER SIZE, DIM, N, i, j, k, matrix(SIZE,SIZE)
      REAL*8 E, M, dE, sum, exponentials(0:DIM), randv

      do k = 1, N
        call random_number(randv)
        j = int(randv*SIZE) + 1
        call random_number(randv)
        i = int(randv*SIZE) + 1

        sum = 0.0
        if (i+1.gt.SIZE) then
          sum = sum + matrix(1,j)
          sum = sum + matrix(i-1,j)
        else if (i-1.eq.0) then
          sum = sum + matrix(SIZE,j)
          sum = sum + matrix(i+1,j)
        else
          sum = sum + matrix(i+1,j)
          sum = sum + matrix(i-1,j)
        end if
        if (j+1.gt.SIZE) then
          sum = sum + matrix(i,1)
          sum = sum + matrix(i,j-1)
        else if (j-1.eq.0) then
          sum = sum + matrix(i,SIZE)
          sum = sum + matrix(i,j+1)
        else
          sum = sum + matrix(i,j+1)
          sum = sum + matrix(i,j-1)
        end if

        dE = 2*matrix(i,j)*sum
        if (dE.le.0) then
          matrix(i,j) = -matrix(i,j)
          E = E + dE
          M = M + matrix(i,j)*2
        else
          call random_number(randv)
          if (randv.lt.exponentials(int(dE/2/2)))
     &    then
            matrix(i,j) = -matrix(i,j)
            E = E + dE
            M = M + matrix(i,j)*2
          end if
        end if
      end do

      END SUBROUTINE


      ! ===========================================
      !            RUN GLAUBER
      ! ===========================================
      SUBROUTINE RUN_GLAUBER(L)
      IMPLICIT NONE
      INTEGER L, N, DIM, JMAG, STEPS
      PARAMETER(DIM=2, JMAG=1, STEPS=20000)
      INTEGER, ALLOCATABLE :: matrix(:,:)
      REAL*8, ALLOCATABLE :: energies(:), mags(:)
      REAL*8 exponentials(-DIM:DIM), E, M
      REAL*8 avg_e, avg_m, avg_e2
      REAL itemp, dtemp, ftemp
      INTEGER i, j, k
      CHARACTER(256) fname

      N = L*L
      ALLOCATE(matrix(L,L))
      ALLOCATE(energies(STEPS), mags(STEPS))

      itemp = 0.2
      dtemp = 0.2
      ftemp = 5.0

      call INITIALIZE(matrix, L, E, M, JMAG)

      write(fname,'(A,I0,A)') 'glauber_2d_L', L, '.txt'
      open(11, File=trim(fname))

      do i = int((ftemp-itemp)/dtemp), 0, -1
        print*, "  [Glauber] T =", itemp+i*dtemp
        do k = -DIM, DIM
          exponentials(k) =
     &      1/(exp(2.0*JMAG*2.0*k
     &      /(itemp+i*dtemp))+1)
        end do

        energies = 0
        mags = 0
        do j = 1, STEPS
          call GLAUBER_MC_STEP(matrix, L, E, M,
     &                        N, DIM, exponentials)
          energies(j) = E
          mags(j) = M
        end do

        avg_e = 0
        avg_m = 0
        avg_e2 = 0
        do j = 10001, STEPS
          avg_e = avg_e + energies(j)
          avg_m = avg_m + abs(mags(j))
          avg_e2 = avg_e2 + (energies(j)**2)
        end do
        write(11,*) itemp+i*dtemp, avg_e/10000/N,
     &    avg_m/10000/N,
     &    (avg_e2/10000 - (avg_e/10000)**2)
     &    /(N*dble(itemp+i*dtemp)**2)
      end do

      close(11)
      DEALLOCATE(matrix, energies, mags)

      END SUBROUTINE


      ! ===========================================
      !       GLAUBER MONTE CARLO STEP
      ! ===========================================
      SUBROUTINE GLAUBER_MC_STEP(matrix, SIZE,
     &            E, M, N, DIM, exponentials)
      IMPLICIT NONE
      INTEGER SIZE, DIM, N, i, j, k, matrix(SIZE,SIZE)
      REAL*8 E,M,dE,sum,exponentials(-DIM:DIM),randv

      do k = 1, N
        call random_number(randv)
        j = int(randv*SIZE) + 1
        call random_number(randv)
        i = int(randv*SIZE) + 1

        sum = 0.0
        if (i+1.gt.SIZE) then
          sum = sum + matrix(1,j)
          sum = sum + matrix(i-1,j)
        else if (i-1.eq.0) then
          sum = sum + matrix(SIZE,j)
          sum = sum + matrix(i+1,j)
        else
          sum = sum + matrix(i+1,j)
          sum = sum + matrix(i-1,j)
        end if
        if (j+1.gt.SIZE) then
          sum = sum + matrix(i,1)
          sum = sum + matrix(i,j-1)
        else if (j-1.eq.0) then
          sum = sum + matrix(i,SIZE)
          sum = sum + matrix(i,j+1)
        else
          sum = sum + matrix(i,j+1)
          sum = sum + matrix(i,j-1)
        end if

        dE = 2*matrix(i,j)*sum
        call random_number(randv)
        if (randv.lt.exponentials(int(dE/2/2)))
     &  then
          matrix(i,j) = -matrix(i,j)
          E = E + dE
          M = M + matrix(i,j)*2
        end if
      end do

      END SUBROUTINE


      ! ===========================================
      !             RUN WOLFF
      ! ===========================================
      SUBROUTINE RUN_WOLFF(L)
      IMPLICIT NONE
      INTEGER L, N, DIM, JMAG, STEPS
      PARAMETER(DIM=2, JMAG=1, STEPS=20000)
      INTEGER, ALLOCATABLE :: matrix(:,:)
      REAL*8, ALLOCATABLE :: energies(:), mags(:)
      REAL*8 E, M, padd, avg_e, avg_m, avg_e2
      REAL itemp, dtemp, ftemp
      INTEGER i, j
      CHARACTER(256) fname

      N = L*L
      ALLOCATE(matrix(L,L))
      ALLOCATE(energies(STEPS), mags(STEPS))

      itemp = 0.2
      dtemp = 0.2
      ftemp = 5.0

      call INITIALIZE(matrix, L, E, M, JMAG)

      write(fname,'(A,I0,A)') 'wolff_2d_L', L, '.txt'
      open(12, File=trim(fname))

      do i = int((ftemp-itemp)/dtemp), 0, -1
        print*, "  [Wolff] T =", itemp+i*dtemp
        padd = 1-exp(-2.0/(itemp+i*dtemp))

        energies = 0
        mags = 0
        do j = 1, STEPS
          call WOLFF_MC_STEP(matrix, L, E, M,
     &                       N, padd)
          energies(j) = E
          mags(j) = M
        end do

        avg_e = 0
        avg_m = 0
        avg_e2 = 0
        do j = 6001, STEPS
          avg_e = avg_e + energies(j)
          avg_m = avg_m + abs(mags(j))
          avg_e2 = avg_e2 + (energies(j)**2)
        end do
        write(12,*) itemp+i*dtemp, avg_e/14000/N,
     &    avg_m/14000/N,
     &    (avg_e2/14000 - (avg_e/14000)**2)
     &    /(N*dble(itemp+i*dtemp)**2)
      end do

      close(12)
      DEALLOCATE(matrix, energies, mags)

      END SUBROUTINE


      ! ===========================================
      !        WOLFF MONTE CARLO STEP
      ! ===========================================
      SUBROUTINE WOLFF_MC_STEP(smatrix, SIZE,
     &            E, M, N, padd)
      IMPLICIT NONE
      INTEGER SIZE, N, smatrix(SIZE, SIZE)
      REAL*8 E, M, padd
      REAL*8 randv, dE_total
      INTEGER stack_i(N), stack_j(N)
      INTEGER clust_i(N), clust_j(N)
      INTEGER visited(SIZE, SIZE)
      INTEGER si, sj, ni, nj
      INTEGER seed_spin
      INTEGER top, nclust, c

      call random_number(randv)
      si = int(randv*SIZE) + 1
      call random_number(randv)
      sj = int(randv*SIZE) + 1
      seed_spin = smatrix(si, sj)

      visited = 0
      visited(si, sj) = 1
      top = 1
      stack_i(1) = si
      stack_j(1) = sj
      nclust = 0

      do while (top .gt. 0)
        si = stack_i(top)
        sj = stack_j(top)
        top = top - 1
        nclust = nclust + 1
        clust_i(nclust) = si
        clust_j(nclust) = sj

C       Right neighbor
        ni = mod(si, SIZE) + 1
        nj = sj
        if (visited(ni,nj).eq.0 .and.
     &      smatrix(ni,nj).eq.seed_spin) then
          call random_number(randv)
          if (randv.lt.padd) then
            visited(ni,nj) = 1
            top = top + 1
            stack_i(top) = ni
            stack_j(top) = nj
          end if
        end if

C       Left neighbor
        ni = mod(si - 2 + SIZE, SIZE) + 1
        nj = sj
        if (visited(ni,nj).eq.0 .and.
     &      smatrix(ni,nj).eq.seed_spin) then
          call random_number(randv)
          if (randv.lt.padd) then
            visited(ni,nj) = 1
            top = top + 1
            stack_i(top) = ni
            stack_j(top) = nj
          end if
        end if

C       Down neighbor
        ni = si
        nj = mod(sj, SIZE) + 1
        if (visited(ni,nj).eq.0 .and.
     &      smatrix(ni,nj).eq.seed_spin) then
          call random_number(randv)
          if (randv.lt.padd) then
            visited(ni,nj) = 1
            top = top + 1
            stack_i(top) = ni
            stack_j(top) = nj
          end if
        end if

C       Up neighbor
        ni = si
        nj = mod(sj - 2 + SIZE, SIZE) + 1
        if (visited(ni,nj).eq.0 .and.
     &      smatrix(ni,nj).eq.seed_spin) then
          call random_number(randv)
          if (randv.lt.padd) then
            visited(ni,nj) = 1
            top = top + 1
            stack_i(top) = ni
            stack_j(top) = nj
          end if
        end if
      end do

C     Compute energy change and flip cluster
      dE_total = 0.0d0
      do c = 1, nclust
        si = clust_i(c)
        sj = clust_j(c)

        ni = mod(si, SIZE) + 1
        if (visited(ni,sj).eq.0) then
          dE_total = dE_total +
     &      2.0d0*smatrix(si,sj)*smatrix(ni,sj)
        end if
        ni = mod(si - 2 + SIZE, SIZE) + 1
        if (visited(ni,sj).eq.0) then
          dE_total = dE_total +
     &      2.0d0*smatrix(si,sj)*smatrix(ni,sj)
        end if
        nj = mod(sj, SIZE) + 1
        if (visited(si,nj).eq.0) then
          dE_total = dE_total +
     &      2.0d0*smatrix(si,sj)*smatrix(si,nj)
        end if
        nj = mod(sj - 2 + SIZE, SIZE) + 1
        if (visited(si,nj).eq.0) then
          dE_total = dE_total +
     &      2.0d0*smatrix(si,sj)*smatrix(si,nj)
        end if

        smatrix(si,sj) = -smatrix(si,sj)
      end do

      E = E + dE_total
      M = M - 2.0d0 * seed_spin * nclust

      END SUBROUTINE